{
  "name": "design2code",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "dev": "turbo dev",
    "dev:dotcom": "turbo dev --filter=@design2code/dotcom",
    "dev:prompt2code": "turbo dev --filter=@design2code/prompt2code",
    "dev:figma2code": "turbo dev --filter=@design2code/figma2code",
    "studio": "npm run dev:studio --workspace=@design2code/dotcom",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test"
  },
  "packageManager": "npm@10.9.2",
  "devDependencies": {
    "patch-package": "^8.0.1",
    "turbo": "^2.9.3",
    "typescript": "^5.6.0"
  }
}
