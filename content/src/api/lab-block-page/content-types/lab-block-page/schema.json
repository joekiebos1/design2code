        "blocks.proof-points",
        "blocks.icon-grid",
        "blocks.media-text-asymmetric",
        "blocks.full-bleed-vertical-carousel",
        "blocks.rotating-media",
        "blocks.media-zoom-out-on-scroll",
        "blocks.editorial-block"
      ]
