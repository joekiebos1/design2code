# Sanity (create project at sanity.io/manage, then set these)
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# For Next.js front-end (fetching content)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# For seed script and Presentation/draft mode (create token with Editor permissions at sanity.io/manage)
SANITY_API_TOKEN=

# Optional: Preview URL for Presentation tool and Configure with Claude API (default: http://localhost:3000)
# Studio calls Next app at this URL. Both must run locally (Studio :3333, Next :3000).
# SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
# SANITY_STUDIO_APP_URL=http://localhost:3000

# Optional: Studio URL for click-to-edit overlays (default: http://localhost:3333)
# SANITY_STUDIO_URL=http://localhost:3333

# Figma REST API — import frames + TEXT into Figma2Code (scripts/import-figma-to-sanity.ts)
# Create at: Figma → Settings → Account → Personal access tokens (needs access to the file)
# FIGMA_ACCESS_TOKEN=

# For JioKarna (AI-powered page builder)
ANTHROPIC_API_KEY=

# Optional: Art Director (n8n) webhook URL. When set, image stream POSTs to this URL
# and streams events from callbacks at /api/images/ready.
# IMAGE_SERVICE_URL=https://your-n8n-webhook.example

# Site password — protects all three apps behind a login screen.
# Leave empty or unset to disable password protection.
SITE_PASSWORD=

# Optional: Debug grid overlays (red column stripes). Restart dev server after changing.
# NEXT_PUBLIC_DEBUG_GRID=true        # Main/public Grid (blocks, page layout)
# NEXT_PUBLIC_DEBUG_EDITORIAL_GRID=true   # Editorial block 12×6 composition grid

# Supabase DAM — Digital Asset Management (approved images for art direction)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Supabase CMS — Studio Tools + Lab media storage (separate from DAM)
NEXT_PUBLIC_SUPABASE_URL=https://your-cms-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
CMS_SUPABASE_SECRET_KEY=sb_secret_xxx

# Optional: Callback base URL for test-images. When running a Cloudflare tunnel to localhost,
# set this to your tunnel URL (e.g. https://xxx.trycloudflare.com) so the webhook can POST back.
# CALLBACK_BASE_URL=https://your-tunnel.trycloudflare.com
